# Personal AI Employee — Environment Configuration
# Copy this file and fill in your values. Never commit to git.

# ── Core ─────────────────────────────────────────────────────────────────────
VAULT_PATH=

# Set to false once Gmail + LinkedIn are configured and tested
DRY_RUN=

# How often (seconds) the orchestrator polls /Needs_Action for new tasks
CLAUDE_INTERVAL=

# ── Gmail ────────────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_PROCESSED_IDS_PATH=
GMAIL_HISTORY_ID_PATH=

# Gmail search query — only fetch emails matching this filter
GMAIL_QUERY=

# How often (seconds) Gmail Watcher polls for new emails
GMAIL_CHECK_INTERVAL=

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_SESSION_PATH=

# ── Scheduler ────────────────────────────────────────────────────────────────
# Time (HH:MM) for daily briefing
DAILY_BRIEFING_TIME=

# Day of week for CEO briefing: 0=Monday … 6=Sunday
WEEKLY_BRIEFING_DAY=

# ── Facebook / Instagram ─────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Odoo ─────────────────────────────────────────────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_MASTER_PASSWORD=
