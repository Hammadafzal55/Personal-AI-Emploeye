# Personal AI Employee — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit it to version control.
# Rotate all credentials monthly (see Company_Handbook.md Section 7).

# ── Core ─────────────────────────────────────────────────────────────────────

# Absolute or relative path to the Obsidian vault folder
VAULT_PATH=AI_Employee_Vault

# How often (seconds) the orchestrator polls /Needs_Action for Claude
CLAUDE_INTERVAL=120

# Dry run mode: true = log actions only, never call Claude/Gmail/LinkedIn
# Set to false when you are ready to go live
DRY_RUN=true

# ── Scheduling ────────────────────────────────────────────────────────────────

# Time for the daily briefing (24h HH:MM format)
DAILY_BRIEFING_TIME=08:00

# Day for the weekly CEO briefing: 0=Monday ... 6=Sunday
WEEKLY_BRIEFING_DAY=0

# ── Gmail (Silver Tier) ───────────────────────────────────────────────────────
# Setup steps:
#   1. Go to console.cloud.google.com → create project → enable Gmail API
#   2. Create OAuth 2.0 credentials (Desktop App) → download JSON
#   3. Save the JSON to: secrets/gmail_credentials.json
#   4. Run: python setup/gmail_oauth_setup.py   (opens browser for login)
#   5. Token saved automatically to: secrets/gmail_token.json
#   6. Uncomment the two lines below

# GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
# GMAIL_TOKEN_PATH=secrets/gmail_token.json

# Gmail search query (what emails to watch)
# GMAIL_QUERY=is:unread

# How often Gmail Watcher polls (seconds)
# GMAIL_CHECK_INTERVAL=120

# ── LinkedIn (Silver Tier) ────────────────────────────────────────────────────
# Setup steps:
#   1. Install Playwright: pip install playwright && playwright install chromium
#   2. Run: python actions/post_linkedin.py --setup
#   3. Log into LinkedIn in the browser that opens, then press Ctrl+C
#   4. Session saved to: secrets/linkedin_session/
#   5. Uncomment the line below

# LINKEDIN_SESSION_PATH=secrets/linkedin_session

# ── WhatsApp (Gold Tier) ──────────────────────────────────────────────────────
# WHATSAPP_SESSION_PATH=secrets/whatsapp_session

# ── Banking / Finance (Gold Tier) ─────────────────────────────────────────────
# BANK_API_TOKEN=your_token

# ── Odoo ERP (Gold Tier) ──────────────────────────────────────────────────────
# ODOO_URL=http://localhost:8069
# ODOO_DB=your_database
# ODOO_USERNAME=admin
# ODOO_PASSWORD=your_password
